# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real tokens.

# Required for Evidently Cloud upload (get yours at app.evidently.cloud → Settings → API Keys)
EVIDENTLY_API_TOKEN=your_token_here

# Optional: pin to a specific project UUID. If omitted, the first project in your workspace is used.
EVIDENTLY_PROJECT_ID=

# Leave as-is unless you are on a self-hosted Evidently deployment.
EVIDENTLY_CLOUD_URL=https://app.evidently.cloud
